MACHINE ??= "raspberrypi5"

DISTRO ?= "poky-sota"

EXTRA_IMAGE_FEATURES ?= "debug-tweaks allow-empty-password allow-root-login empty-root-password serial-autologin-root ssh-server-openssh package-management splash hwcodecs nfs-server x11 x11-base"

USER_CLASSES ?= "buildstats"

PATCHRESOLVE = "noop"

BB_DISKMON_DIRS ??= "\
    STOPTASKS,${TMPDIR},1G,100K \
    STOPTASKS,${DL_DIR},1G,100K \
    STOPTASKS,${SSTATE_DIR},1G,100K \
    STOPTASKS,/tmp,100M,100K \
    HALT,${TMPDIR},100M,1K \
    HALT,${DL_DIR},100M,1K \
    HALT,${SSTATE_DIR},100M,1K \
    HALT,/tmp,10M,1K"

PACKAGECONFIG:append:pn-qemu-system-native = " sdl"

CONF_VERSION = "2"

########################################

require conf/distro/include/default.inc
require conf/machine/include/default.inc

# BBMULTICONFIG = "initramfs-musl"
# bINITRAMFS_MULTICONFIG = "initramfs-musl"
